{
  "name": "@playcanvas/engine",
  "version": "1.0.0",
  "description": "Fast and lightweight JavaScript game engine built on WebGL and glTF",
  "main": "build/playcanvas.js",
  "module": "build/playcanvas.mjs",
  "types": "build/playcanvas.d.ts",
  "exports": {
    ".": {
      "import": "./build/playcanvas.mjs",
      "require": "./build/playcanvas.js",
      "types": "./build/playcanvas.d.ts"
    },
    "./debug": {
      "import": "./build/playcanvas.dbg.mjs",
      "require": "./build/playcanvas.dbg.js",
      "types": "./build/playcanvas.d.ts"
    }
  },
  "scripts": {
    "build": "rollup -c",
    "build:debug": "rollup -c --environment BUILD:debug",
    "build:profiler": "rollup -c --environment BUILD:profiler",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix",
    "test": "mocha --recursive test",
    "test:watch": "mocha --recursive test --watch",
    "docs": "jsdoc -c conf.json",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/playcanvas/engine.git"
  },
  "keywords": [
    "playcanvas",
    "webgl",
    "webgpu",
    "game",
    "engine",
    "3d",
    "graphics",
    "gltf"
  ],
  "author": "PlayCanvas <support@playcanvas.com>",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-replace": "^5.0.0",
    "chai": "^4.3.7",
    "eslint": "^8.40.0",
    "eslint-plugin-import": "^2.27.5",
    "jsdoc": "^4.0.2",
    "mocha": "^10.2.0",
    "rollup": "^3.21.0",
    "rollup-plugin-jscc": "^2.0.0",
    "sinon": "^15.0.4",
    "typescript": "^5.0.4"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
